{
  "name": "sf-pipeline",
  "version": "1.0.0",
  "description": "Salesforce async data pipeline",
  "main": "server/index.js",
  "bin": "server/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "build:client": "cd client && npm install && npm run build",
    "build:exe": "node scripts/build-exe.js"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "express": "^4.18.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "pkg": "5.8.1"
  },
  "pkg": {
    "assets": [
      "client/dist/**",
      "jobs/**",
      "server/pipeline/workerRunner.js",
      "server/plugins/**/*.worker.js",
      "node_modules/better-sqlite3/build/Release/better_sqlite3.node"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist-exe"
  }
}
